# ── NovTurnIA — variables de entorno ──────────────────────────────
# Copiá este archivo a .env y completá los valores.
# En Vercel, configurá las mismas variables en Project Settings → Environment Variables.

# ── Supabase (REQUERIDAS) ─────────────────────────────────────────
# Las encontrás en Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Super Admin (REQUERIDA) ───────────────────────────────────────
# Email del owner del SaaS. Habilita la ruta /admin/new-tenant para crear
# nuevos negocios desde el frontend. Solo este email puede acceder a esa ruta.
# Si no lo seteás, /admin/new-tenant queda deshabilitado.
VITE_SUPER_ADMIN_EMAIL=tu@email.com

# ── Sentry (OPCIONAL, recomendada en producción) ─────────────────
# Captura errores en producción. Si no la seteás, Sentry queda desactivado.
# Crear en sentry.io → Project Settings → Client Keys (DSN).
# VITE_SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
